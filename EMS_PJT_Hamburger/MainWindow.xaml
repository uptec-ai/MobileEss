                                   GlyphSize="Custom" CustomGlyphSize="23,23" Margin="0,0,0,0"
                                   Glyph="{dx:DXImage 'SvgImages/Icon Builder/Actions_Comment.svg'}"
                                   Content="{Binding StatusManager.CommState, Source={x:Static Application.Current}}">
                    <dxb:BarStaticItem.ContentTemplate>
                        <DataTemplate>
