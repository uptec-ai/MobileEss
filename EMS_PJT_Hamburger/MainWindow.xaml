                                   Glyph="{dx:DXImage 'SvgImages/XAF/State_Task_InProgress.svg'}"
                                   Content="{Binding StatusManager.CurrentTime, Source={x:Static Application.Current}}" >
                    <dxb:BarStaticItem.ContentTemplate>
