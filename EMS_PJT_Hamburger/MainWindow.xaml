<dx:ThemedWindow 
    x:Class="EMS_PJT_Hamburger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:dxwui="http://schemas.devexpress.com/winfx/2008/xaml/windowsui" 
    xmlns:dxr="http://schemas.devexpress.com/winfx/2008/xaml/ribbon" 
    xmlns:dxrt="http://schemas.devexpress.com/winfx/2008/xaml/ribbon/themekeys"
    xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars" 
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm" 
    xmlns:Views="clr-namespace:EMS_PJT_Hamburger.Views"
    Title="Outside EMS PJT" 
    Height="768" Width="1024" Background="{DynamicResource Main.Background}"
    WindowStartupLocation="CenterScreen"
    WindowState="Normal"
    WindowStyle="ToolWindow"
    FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR" Loaded="ThemedWindow_Loaded">
    <dx:ThemedWindow.Resources>
        <Style TargetType="{x:Type dxwui:HamburgerMenuNavigationButton}">
            <Setter Property="FontFamily" Value="/EMS_PJT_Hamburger;component/Fonts/#Jalnan 2"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="0,10,10,10"/>
            <Setter Property="GlyphWidth" Value="32"/>
            <Setter Property="GlyphHeight" Value="32"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="AllowGlyphTheming" Value="True"/>
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#244A33"/>
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2F8F46"/>
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <ControlTemplate x:Key="{dxrt:RibbonStatusBarThemeKey ResourceKey=LeftPartTemplate, IsThemeIndependent=true}" TargetType="{x:Type ContentControl}">
            <Border Background="{Binding Path=Background, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=dxr:RibbonStatusBarControl}}">
                <ContentPresenter Margin="1,1,0,0" />
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="{dxrt:RibbonStatusBarThemeKey ResourceKey=RightPartTemplate, IsThemeIndependent=true}" TargetType="{x:Type ContentControl}">
            <Border Background="{Binding Path=Background, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=dxr:RibbonStatusBarControl}}">
                <ContentPresenter Margin="1,1,0,0" />
            </Border>
        </ControlTemplate>
    </dx:ThemedWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>
        
        <ContentControl x:Name="WarmupHost"
                    Width="1"
                    Height="1"
                    Opacity="0.01"
                    IsHitTestVisible="False"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"/>

        <dxwui:HamburgerMenu Grid.Row="0" Grid.Column="0" AvailableViewStates="Overlay" 
                             Background="{DynamicResource Main.Background}" 
                             PaneBackground="{DynamicResource Main.Panel.Background}" 
                             FontFamily="/EMS_PJT_Hamburger;component/Fonts/#NanumSquareRound ExtraBold" >
            <dxwui:HamburgerMenu.Content>
                <dxwui:NavigationFrame x:Name="NaviFrame" BorderThickness="1,0,0,0"/>
            </dxwui:HamburgerMenu.Content>
            <!--Home--><!--
            <dxwui:HamburgerMenuNavigationButton x:Name="Btn_Home" 
                                                 Content="HOME" 
                                                 ToolTip="HOME VIEW" 
                                                 IsSelected="True"
                                                 Glyph="{dx:DXImage GrayScaleImages/Navigation/Home_32x32.png}" Click="Btn_Home_Click"/>-->

            <!-- Dashboard -->
            <dxwui:HamburgerMenuNavigationButton x:Name="Btn_Dashboard"
                                                 Content="DASHBOARD" 
                                                 ToolTip="DASHBOARD VIEW" 
                                                 IsSelected="True"
                                                 Glyph="{dx:DXImage SvgImages/Icon Builder/Electronics_DesktopMac.svg}" Click="Btn_Dashboard_Click"/>

            <!-- PCS Status -->
            <dxwui:HamburgerMenuNavigationButton x:Name="Btn_PcsStatus" 
                                                 Content="PCS STATUS" 
                                                 ToolTip="PCS STATUS VIEW" 
                                                 Glyph="/EMS_PJT_Hamburger;component/Assets/PCS_View.png" Click="Btn_PcsStatus_Click" />

            <!-- BMS Status -->
            <dxwui:HamburgerMenuNavigationButton x:Name="Btn_BmsStatus" 
                                                 Content="BMS STATUS" 
                                                 ToolTip="BMS STATUS VIEW"
                                                 Glyph="/EMS_PJT_Hamburger;component/Assets/BMS_View.png" Click="Btn_BmsStatus_Click"/>

            <!-- System Status --><!--
            <dxwui:HamburgerMenuNavigationButton x:Name="Btn_SystemStatus" 
                                                 Content="SYSTEM STATUS" 
                                                 ToolTip="SYSTEM STATUS VIEW"
                                                 Glyph="{dx:DXImage SvgImages/XAF/Navigation_Item_Dashboard.svg}" Click="Btn_SystemStatus_Click"/>-->

            <!-- History -->
            <dxwui:HamburgerMenuNavigationButton x:Name="Btn_History" 
                                                 Content="HISTORY" 
                                                 ToolTip="HISTORY VIEW"
                                                 Glyph="{dx:DXImage SvgImages/RichEdit/DocumentStatistics.svg}" Click="Btn_History_Click"/>

            
            
            <dxwui:HamburgerMenuItemSeparator Height="10" Background="#FFBFBFBF"/>

            <dxwui:HamburgerMenuItemSeparator Height="10" Placement="Bottom" Background="#FFBFBFBF"/>

            <!--Uptec Info-->
            <dxwui:HamburgerMenuNavigationButton Content="UPTEC" ToolTip="Uptec Info"
                                                 GlyphWidth="32" GlyphHeight="32" Placement="Bottom" Glyph="Assets/Uptec_symbol_White4.png" GlyphStretch="UniformToFill"
                                                 Click="InfoBtn_Click"/>
            <!--System Close-->
            <dxwui:HamburgerMenuNavigationButton x:Name="ExitBtn" Content="Exit" ToolTip="Close App" Placement="Bottom"
                                                 GlyphWidth="32" GlyphHeight="32" AllowGlyphTheming="True" Glyph="{dx:DXImage 'SvgImages/Dashboards/Delete.svg'}"
                                                 Click="ExitBtn_Click"/>
        </dxwui:HamburgerMenu>

        <!--Log-->
        <dxr:RibbonStatusBarControl HorizontalAlignment="Stretch" Grid.Row="1" VerticalAlignment="Stretch" Background="White">
            <dxr:RibbonStatusBarControl.LeftItems>
                <!--PCS-->
                <dxb:BarStaticItem ShowBorder="False" 
                                   AllowGlyphTheming="True"
                                   GlyphSize="Custom" CustomGlyphSize="23,23" Margin="0,0,0,0"
                                   Glyph="{dx:DXImage 'SvgImages/Icon Builder/Electronics_Router.svg'}"
                                   Content="{Binding StatusManager.PCS, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}">
                    <dxb:BarStaticItem.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="10,0,0,0" FontSize="14" FontWeight="Normal" VerticalAlignment="Center" 
                                       FontFamily="/EMS_PJT_Hamburger;component/Fonts/#NanumSquareRound Bold"/>
                        </DataTemplate>
                    </dxb:BarStaticItem.ContentTemplate>
                </dxb:BarStaticItem>
                <dxb:BarStaticItem Content="        " ShowBorder="False"/>

                <!--BMS-->
                <dxb:BarStaticItem ShowBorder="False" 
                                   AllowGlyphTheming="True"
                                   GlyphSize="Custom" CustomGlyphSize="23,23" Margin="0,0,0,0"
                                   Glyph="{dx:DXImage 'SvgImages/Icon Builder/Electronics_Router.svg'}"
                                   Content="{Binding StatusManager.BMS, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}">
