<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- 운영 시 app.config에 직접 보관하지 말고 환경변수 EMS_SCICHART_LICENSE_KEY 사용 권장 -->
    <add key="PcsHost" value="127.0.0.1" />
    <add key="PcsPort" value="502" />
    <add key="PcsTimeoutMs" value="10000" />
  </appSettings>
