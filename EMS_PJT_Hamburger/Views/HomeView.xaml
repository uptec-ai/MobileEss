                    <Image Source="/EMS_PJT_Hamburger;component/Assets/Transformer.png" 
                           Canvas.Left="14" Canvas.Top="18"
                           Style="{StaticResource DefaultImageStyle}" Width="50" Height="50" Stretch="Fill"/>

                </Canvas>
            </Border>

            <Border Canvas.Left="659" Canvas.Top="256"
