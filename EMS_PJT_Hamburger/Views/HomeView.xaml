                  Visibility="Visible"
                  Style="{StaticResource DisChargingPathStyle}">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="710,345" IsClosed="False">
                            <LineSegment Point="710,500"/>
                            <LineSegment Point="920,500"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
            <!--#endregion-->

            <!-- 자연 에너지 -->

