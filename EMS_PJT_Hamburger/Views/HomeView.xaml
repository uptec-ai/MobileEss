                    </TextBlock>

                    <Label Canvas.Left="167" Canvas.Top="4"
                           Content="Enable"
                           Style="{StaticResource ConnLableStyle}"/>

                    <Label Canvas.Left="172" Canvas.Top="28"
                           Style="{StaticResource InfoLableStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Va"/>
                            <Ellipse Width="5" Height="5" Margin="4,1,0,0" Fill="GreenYellow"/>
                        </StackPanel>
                    </Label>

                    <Label Canvas.Left="172" Canvas.Top="47"
                           Style="{StaticResource InfoLableStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Vb"/>
                            <Ellipse Width="5" Height="5" Margin="4,1,0,0" Fill="GreenYellow"/>
                        </StackPanel>

                    </Label>

                    <Label Canvas.Left="172" Canvas.Top="66"
