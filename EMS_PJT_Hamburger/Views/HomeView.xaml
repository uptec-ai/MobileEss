                  Managers:AnimationManager.From="0"
                  Managers:AnimationManager.Speed="1.2"
                  Managers:AnimationManager.StartDelaySec="1"
                  Visibility="Visible"
                  Style="{StaticResource ChargingPathStyle}">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="172, 180" IsClosed="False">
                            <LineSegment Point="172,310"/>
                            <LineSegment Point="370,310"/>
                            <LineSegment Point="370,100"/>
                            <LineSegment Point="400,100"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>

