                        <StackPanel Orientation="Vertical">
                            <Image Source="/EMS_PJT_Hamburger;component/Assets/Home/Capacitor neon.png" 
                                   Height="25" 
                                   Width="25"
                                   Style="{StaticResource HeaderImageStyle}"/>
                            <TextBlock Text="Warring"
                                       Style="{StaticResource ContentTextBlockStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Canvas.Left="162" Canvas.Top="112"
                            Style="{StaticResource ContentBorderStyle}">
                        <StackPanel Orientation="Vertical">
                            <Image Source="/EMS_PJT_Hamburger;component/Assets/Home/Warring neon.png" Style="{StaticResource DefaultImageStyle}" Height="25" Margin="9,5,9,0" Width="25"/>
                            <TextBlock Text="Warring" 
                                       Style="{StaticResource ContentTextBlockStyle}"/>
                        </StackPanel>
                    </Border>

                </Canvas>
            </Border>

