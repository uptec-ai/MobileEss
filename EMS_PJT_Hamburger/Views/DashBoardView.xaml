<UserControl 
    x:Class="EMS_PJT_Hamburger.Views.DashBoardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm" 
    xmlns:ViewModels="clr-namespace:EMS_PJT_Hamburger.ViewModels" xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
    mc:Ignorable="d" d:DesignHeight="704" d:DesignWidth="1225" 
    Background="Transparent" FontFamily="/EMS_PJT;component/Fonts/#Noto Sans KR">
    <UserControl.Resources>
        <Style TargetType="StackPanel" x:Key="VerticalStackpanelStyle">
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="221"/>

        </Style>

        <Style TargetType="TextBlock" x:Key="HeadTextBlockStyle">
            <Setter Property="Margin" Value="15"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Setter Property="FontFamily" Value="/EMS_PJT;component/Fonts/#Noto Sans KR"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Label" x:Key="HeadLableStyle">
            <Setter Property="Margin" Value="15,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="/EMS_PJT;component/Fonts/#Noto Sans KR"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Label" x:Key="VariableLableStyle">
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="/EMS_PJT;component/Fonts/#Noto Sans KR - Black"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <UserControl.DataContext>
        <ViewModels:DashBoardViewModel/>
    </UserControl.DataContext>

    <Viewbox>

        <Grid Height="704" Width="1225" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height=".6*"/>
                <RowDefinition Height=".9*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Main Status -->
            <StackPanel Orientation="Horizontal" Grid.ColumnSpan="2">
                <!-- Vegicle status -->
                <Border CornerRadius="5" Margin="20,0,0,0" Background="{DynamicResource Main.Panel.Background}">
                    <!-- Vihicle Status -->
                    <StackPanel Orientation="Vertical" Style="{StaticResource VerticalStackpanelStyle}">
                        <TextBlock Text="VIHICLE STATUS" Style="{StaticResource HeadTextBlockStyle}"/>
                        <Label>
                            <Label.Effect>
                                <DropShadowEffect BlurRadius="0" ShadowDepth="0" Opacity="1"/>
                            </Label.Effect>
                            <Label.Style>
                                <Style TargetType="Label">
                                    <Setter Property="Margin" Value="15,0,15,0"/>
                                    <Setter Property="Height" Value="80"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="{Binding EMSStatusManager.DashboardStatus.VihicleColor, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}">
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Main.MouseOver}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Label.Style>
                            <Label.Content>
                                <TextBlock FontSize="30" FontWeight="Bold" FontFamily="/EMS_PJT;component/Fonts/#Noto Sans KR" Foreground="White">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="0" Opacity="1"/>
                                    </TextBlock.Effect>
                                <Run Text="{Binding EMSStatusManager.DashboardStatus.VihicleStatus, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}" Foreground="White"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </Border>
                <Border CornerRadius="5" Margin="20,0,0,0" Background="{DynamicResource Main.Panel.Background}">
                    <!-- PCS Power -->
                    <StackPanel Orientation="Vertical" Style="{StaticResource VerticalStackpanelStyle}">
                        <TextBlock Text="PCS POWER" Style="{StaticResource HeadTextBlockStyle}"/>
                        <Label Margin="15,0" Height="80" FontSize="36"
                               HorizontalAlignment="Center" VerticalAlignment="Center"                       
                               Style="{StaticResource VariableLableStyle}" >
                            <Label.Content>
                                <TextBlock>
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="0" Opacity="1"/>
                                    </TextBlock.Effect>
                                <Run Text="{Binding EMSStatusManager.DashboardStatus.Power, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}" 
                                     Foreground="#FF29BDAB"/>
                                <Run Text="kW" Foreground="White"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </Border>

                <Border CornerRadius="5" Margin="20,0,0,0" Background="{DynamicResource Main.Panel.Background}">
                    <!-- SOC -->
                    <StackPanel Orientation="Vertical" Style="{StaticResource VerticalStackpanelStyle}">
                        <TextBlock Text="SOC" Style="{StaticResource HeadTextBlockStyle}"/>
                        <Label Margin="15,0" Height="80" FontSize="36" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Style="{StaticResource VariableLableStyle}" >
                            <Label.Content>
                                <TextBlock>
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="0" Opacity="1"/>
                                    </TextBlock.Effect>
                                <Run Text="{Binding EMSStatusManager.DashboardStatus.SOC, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}" 
                                     Foreground="#FF29BDAB"/>
                                <Run Text="%" Foreground="White"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </Border>
                <Border CornerRadius="5" Margin="20,0,0,0" Background="{DynamicResource Main.Panel.Background}">
                    <!--Battery voltage-->
                    <StackPanel Orientation="Vertical" Style="{StaticResource VerticalStackpanelStyle}">
                        <TextBlock Text="BATTERY CAPACITOR" Style="{StaticResource HeadTextBlockStyle}"/>
                        <Label Margin="15,0" Height="80" FontSize="36" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Style="{StaticResource VariableLableStyle}" >
                            <Label.Content>
                                <TextBlock>
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="0" Opacity="1"/>
                                    </TextBlock.Effect>
                                <Run Text="{Binding EMSStatusManager.DashboardStatus.BatteryVoltage, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}" 
                                     Foreground="#FF29BDAB"/>
                                <Run Text="kWh" Foreground="White"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </Border>
                <Border CornerRadius="5" Margin="20,0,0,0" Background="{DynamicResource Main.Panel.Background}">
                    <!-- Communication status -->
                    <StackPanel Orientation="Vertical" Style="{StaticResource VerticalStackpanelStyle}">
                        <TextBlock Text="COMMUNICATION STATUS" Style="{StaticResource HeadTextBlockStyle}"/>
                        <Label Margin="15,0" Height="80" FontSize="36" 
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Style="{StaticResource VariableLableStyle}" >
                            <Label.Content>
                                <TextBlock>
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="0" Opacity="1"/>
                                    </TextBlock.Effect>
                                <Run Text="{Binding EMSStatusManager.DashboardStatus.CommunicationStatus, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}" 
                                     Foreground="#FF29BDAB"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- PCS infomation-->
            <Border Grid.Column="0" Grid.Row="1" Margin="22,15,10,0" CornerRadius="5" Background="{DynamicResource Main.Panel.Background}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Column="0" Grid.Row="0" Content="PCS INFORMATION" FontSize="15" Style="{StaticResource HeadLableStyle}">
                        <Label.Effect>
                            <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="1" Opacity="1"/>
                        </Label.Effect>
                    </Label>

                    <Label Grid.Column="0" Grid.Row="1" Content="Operation Mode" FontWeight="Light" 
                   Style="{StaticResource HeadLableStyle}"/>


                    <Grid Grid.Column="0" Grid.Row="2" >
                        <Label Content="Power" Width="150" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding EMSStatusManager.PcsStatus.PresentPower, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="kW"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>
                    <Grid Grid.Column="0" Grid.Row="3" >
                        <Label Content="DC Voltage" Width="150" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding EMSStatusManager.PcsStatus.PresentDCVoltage, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="V"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>
                    <Grid Grid.Column="0" Grid.Row="4" >
                        <Label Content="Error Code" Width="150" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding EMSStatusManager.PcsStatus.ErrorCode}"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>

                    <Grid Grid.Column="1" Grid.Row="1">
                        <Label Content="Set Power" Width="150" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding EMSStatusManager.PcsStatus.SetPower, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="kW"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>
                    <Grid Grid.Column="1" Grid.Row="2">
                        <Label Content="Current" Width="150" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding EMSStatusManager.PcsStatus.PresentCurrent, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="A"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>
                    <Grid Grid.Column="1" Grid.Row="3">
                        <Label Content="Temperature" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding EMSStatusManager.PcsStatus.Temperature, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="℃"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>

                </Grid>
            </Border>

            <!-- System & Communication status-->
            <Border Grid.Column="0" Grid.Row="2" Margin="22,15,10,0" CornerRadius="5" Background="{DynamicResource Main.Panel.Background}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width=".55*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height=".5*"/>
                    </Grid.RowDefinitions>

                    <Label Grid.ColumnSpan="2" Grid.Row="0" Content="SYSTEM &amp; COMMUNICATION STATUS" FontSize="15" Style="{StaticResource HeadLableStyle}">
                        <Label.Effect>
                            <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="1" Opacity="1"/>
                        </Label.Effect>
                    </Label>
                    <Label Grid.Column="1" Grid.Row="0" Content="BMS INFORMATION" FontWeight="Bold" Style="{StaticResource HeadLableStyle}"/>

                    <Label Grid.Column="0" Grid.Row="1" Content="IPC State"
                   FontWeight="Light" HorizontalAlignment="Left" VerticalAlignment="Center"
                   Style="{StaticResource HeadLableStyle}"/>

                    <Label Grid.Column="0" Grid.Row="2" Content="Communication Status" 
                   FontWeight="Light" HorizontalAlignment="Left" VerticalAlignment="Center"
                   Style="{StaticResource HeadLableStyle}"/>

                    <Label Grid.Column="0" Grid.Row="3" Content="GPS Signal" 
                   FontWeight="Light" HorizontalAlignment="Left" VerticalAlignment="Center"
                   Style="{StaticResource HeadLableStyle}"/>

                    <Grid Grid.Column="1" Grid.Row="1">
                        <Label Content="State of Charge" Width="95" FontWeight="Light" 
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       Style="{StaticResource HeadLableStyle}"/>
                        <Label HorizontalAlignment="Right" Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                                <Run Text="{Binding EMSStatusManager.SystemComm.StateOfCharge, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                <Run Text="%"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>



                    <Grid Grid.Column="1" Grid.Row="2" >
                        <Label Content="State of Health" Width="95" FontWeight="Light" 
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,8"
                       Style="{StaticResource HeadLableStyle}"/>
                        <Label HorizontalAlignment="Right" Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                                <Run Text="{Binding EMSStatusManager.SystemComm.StateOfHealth, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                <Run Text="%"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>



                    <StackPanel Grid.Column="1" Grid.Row="3" Orientation="Horizontal">
                        <Label Content="Cell Voltage Range" FontWeight="Light" 
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,8"
                       Style="{StaticResource HeadLableStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="4" Grid.RowSpan="2" Orientation="Vertical">
                        <Label Content="Cell Temperature Range" FontWeight="Light" 
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,8,0,0"
                       Style="{StaticResource HeadLableStyle}"/>
                        <Label HorizontalAlignment="Right" Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding EMSStatusManager.SystemComm.CellTemperatureRange, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Chart & Status -->
            <Grid Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" Margin="10,15,22,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2.6*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" VerticalAlignment="Stretch" CornerRadius="5" Background="{DynamicResource Main.Panel.Background}">
                    <!-- Chart -->
                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Content="ESS STATUS &amp; REAL-TIME CHART" FontSize="15" Style="{StaticResource HeadLableStyle}">
                            <Label.Effect>
                                <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="1" Opacity="1"/>
                            </Label.Effect>
                        </Label>

                        <s:SciChartSurface Grid.Row="1" Margin="15,0">
                            <!--  Declare RenderableSeries  -->
                            <s:SciChartSurface.RenderableSeries>
                                <s:FastMountainRenderableSeries x:Name="mountainRenderSeries" Fill="LightCyan" Stroke="Cyan" StrokeThickness="2">
                                    <s:FastMountainRenderableSeries.SeriesAnimation>
                                        <s:WaveAnimation AnimationDelay="0:0:0.2" Duration="0:0:2" PointDurationFraction="0.3"/>
                                    </s:FastMountainRenderableSeries.SeriesAnimation>
                                </s:FastMountainRenderableSeries>
                            </s:SciChartSurface.RenderableSeries>

                            <!--  Create an X Axis  -->
                            <s:SciChartSurface.XAxis>
                                <s:DateTimeAxis DrawMajorBands="False" DrawMajorTicks="False" DrawMajorGridLines="False"
                                        DrawMinorGridLines="False" DrawMinorTicks="False"/>
                            </s:SciChartSurface.XAxis>

                            <!--  Create a Y Axis. Optional bands give a cool look and feel for minimal performance impact  -->
                            <s:SciChartSurface.YAxis>
                                <s:NumericAxis DrawMajorBands="False" GrowBy="0.1, 0.1" VisibleRange="0,150" MaxAutoTicks="4"
                                       DrawMajorTicks="False" DrawMajorGridLines="True" 
                                       DrawMinorGridLines="False" DrawMinorTicks="False"/>
                            </s:SciChartSurface.YAxis>

                            <!--  Optional ChartModifier to add interactivity  -->
                            <s:SciChartSurface.ChartModifier>
                                <s:ModifierGroup>
                                    <s:RubberBandXyZoomModifier IsAnimated="False" IsXAxisOnly="True"
                                                        />
                                    <s:ZoomExtentsModifier/>
                                </s:ModifierGroup>
                            </s:SciChartSurface.ChartModifier>

                        </s:SciChartSurface>

                        <Grid Grid.Row="2">
                            <Label Content="Cumulative Charge Energy" FontWeight="Light" 
                           HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource HeadLableStyle}"/>
                            <Label Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                                <Label.Content>
                                    <TextBlock>
                            <Run Text="{Binding EMSStatusManager.EssStatus.CumulativeCharge, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="kWh"/>
                                    </TextBlock>
                                </Label.Content>
                            </Label>
                        </Grid>

                        <Grid Grid.Row="3">
                            <Label Content="Cumulative Discharge Energy" FontWeight="Light" 
                           HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource HeadLableStyle}"/>
                            <Label Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                                <Label.Content>
                                    <TextBlock>
                            <Run Text="{Binding EMSStatusManager.EssStatus.CumulativeDischarge, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="kWh"/>
                                    </TextBlock>
                                </Label.Content>
                            </Label>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" VerticalAlignment="Stretch" Margin="0,15,0,0" CornerRadius="5" Background="{DynamicResource Main.Panel.Background}">
                    <!-- ESS Status -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Label Grid.Row="0" Content="ESS STATUS" FontSize="15" Style="{StaticResource HeadLableStyle}">
                            <Label.Effect>
                                <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="1" Opacity="1"/>
                            </Label.Effect>
                        </Label>

                        <Grid Grid.Row="1">
                            <Label Content="Cumulative Charge Energy" FontWeight="Light" 
                           HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource HeadLableStyle}"/>
                            <Label Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                                <Label.Content>
                                    <TextBlock>
                            <Run Text="{Binding EMSStatusManager.EssStatus.CumulativeCharge, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="kWh"/>
                                    </TextBlock>
                                </Label.Content>
                            </Label>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Label Content="Cumulative Charge Energy" FontWeight="Light" 
                           HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource HeadLableStyle}"/>
                            <Label Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                                <Label.Content>
                                    <TextBlock>
                            <Run Text="{Binding EMSStatusManager.EssStatus.CumulativeDischarge, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="kWh"/>
                                    </TextBlock>
                                </Label.Content>
                            </Label>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

    </Viewbox>
</UserControl>
