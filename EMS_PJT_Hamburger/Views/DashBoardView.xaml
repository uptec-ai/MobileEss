<UserControl 
    x:Class="EMS_PJT_Hamburger.Views.DashBoardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm" 
    xmlns:ViewModels="clr-namespace:EMS_PJT_Hamburger.ViewModels" xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
    mc:Ignorable="d" d:DesignHeight="860" d:DesignWidth="1200" 
    Background="Transparent" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR">
    <UserControl.Resources>
        <Style TargetType="StackPanel" x:Key="VerticalStackpanelStyle">
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="221"/>

        </Style>

        <Style TargetType="TextBlock" x:Key="HeadTextBlockStyle">
            <Setter Property="Margin" Value="15,0,15,15"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Setter Property="FontFamily" Value="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Label" x:Key="HeadLableStyle">
            <Setter Property="Margin" Value="15,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FFACABAB"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Label" x:Key="VariableLableStyle">
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR - Black"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Viewbox>
        <Grid Height="860" Width="1200" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height=".4*"/>
                <RowDefinition Height=".9*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Main Status -->
            <Grid Grid.ColumnSpan="2" Margin="22,0,22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="12" Margin="0,0,0,0" Background="{DynamicResource Main.Panel.Background}">
                    <!-- Vihicle Status -->
                    <StackPanel Orientation="Vertical" Style="{StaticResource VerticalStackpanelStyle}" Width="Auto">
                        <TextBlock Text="VIHICLE STATUS" Style="{StaticResource HeadTextBlockStyle}" Margin="15,10,15,15"/>
                        <!-- 차량 Status -->
                        <Label Content="{Binding EMSStatusManager.DashboardStatus.VihicleStatus, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}" Foreground="White" FontSize="30" FontWeight="Bold" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR" Margin="10,0">
                            <Label.Effect>
                                <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="0" Opacity="1"/>
                            </Label.Effect>
                            <Label.Style>
                                <Style TargetType="Label">
                                    <Setter Property="Margin" Value="10"/>
                                    <Setter Property="Height" Value="80"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </Label.Style>
                        </Label>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" CornerRadius="12" Margin="10,0,0,0" Background="{DynamicResource Main.Panel.Background}">
                    <!-- PCS Power -->
                    <StackPanel Orientation="Vertical" Style="{StaticResource VerticalStackpanelStyle}" Width="Auto">
                        <TextBlock Text="PCS POWER" Style="{StaticResource HeadTextBlockStyle}" Margin="15,10,15,15"/>

                        <!-- PCS inv_유효전력 -->
                        <Label Margin="15,0" Height="80" FontSize="36"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"                       
                                   Style="{StaticResource VariableLableStyle}" >
                            <Label.Content>
                                <TextBlock>
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="0" Opacity="1"/>
                                    </TextBlock.Effect>
                                    <Run Text="{Binding PcsVm.InvData.Power, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Run Text="kW" Foreground="White"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </Border>

                <!-- SOC -->
                <Border Grid.Column="2" CornerRadius="12" Margin="10,0,0,0" Background="{DynamicResource Main.Panel.Background}">
                    <StackPanel Orientation="Vertical" Style="{StaticResource VerticalStackpanelStyle}" Width="Auto">
                        <TextBlock Text="SOC" Style="{StaticResource HeadTextBlockStyle}" Margin="15,10,15,15"/>
                        <!-- BMS Disp_SOC -->
                        <Label Margin="15,0" Height="80" FontSize="36" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Style="{StaticResource VariableLableStyle}" >
                            <Label.Content>
                                <TextBlock>
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="0" Opacity="1"/>
                                    </TextBlock.Effect>
                                    <Run Text="{Binding BmsVm.StatusMsg01.DispSOC, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Run Text="%" Foreground="White"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </Border>

                <!--Battery voltage-->
                <Border Grid.Column="3" CornerRadius="12" Margin="10,0,0,0" Background="{DynamicResource Main.Panel.Background}">
                    <StackPanel Orientation="Vertical" Style="{StaticResource VerticalStackpanelStyle}" Width="Auto">
                        <TextBlock Text="Battery Current" Style="{StaticResource HeadTextBlockStyle}" Margin="15,10,15,15"/>
                        <Label Margin="15,0" Height="80" FontSize="36" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Style="{StaticResource VariableLableStyle}" >
                            <Label.Content>
                                <TextBlock>
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="0" Opacity="1"/>
                                    </TextBlock.Effect>
                                    <Run Text="{Binding BmsVm.StatusMsg01.TotalCurrent, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Run Text="kWh" Foreground="White"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </Border>

                <!-- Communication status -->
                <StackPanel Orientation="Vertical" Grid.Column="4">
                    <Border CornerRadius="12" Margin="10,0,0,0" Background="{DynamicResource Main.Panel.Background}">
                    <StackPanel Orientation="Vertical" Style="{StaticResource VerticalStackpanelStyle}" Margin="0" Width="Auto">
                            <TextBlock Text="PCS COMMUNICATION" Style="{StaticResource HeadTextBlockStyle}" Margin="15,10,15,5.1"/>
                            <Label FontSize="24" 
                               HorizontalAlignment="Left" VerticalAlignment="Center"
                               Style="{StaticResource VariableLableStyle}" Margin="40,0,0,0" >
                            <Label.Content>
                                <TextBlock>
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="0" Opacity="1"/>
                                        </TextBlock.Effect>
                                        <Run Text="{Binding PcsVm.PanelData.Status, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </Border>
                    <Border  CornerRadius="12" Margin="10,10,0,0" Background="{DynamicResource Main.Panel.Background}">
                        <StackPanel Orientation="Vertical" Style="{StaticResource VerticalStackpanelStyle}" Margin="0" Width="Auto">
                            <TextBlock Text="BMS COMMUNICATION" Style="{StaticResource HeadTextBlockStyle}" Margin="15,10,15,5"/>
                            <Label FontSize="24" 
                               HorizontalAlignment="Left" VerticalAlignment="Center"
                               Style="{StaticResource VariableLableStyle}" Margin="38,0,0,0">
                                <Label.Content>
                                    <TextBlock>
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="Black" Direction="320" ShadowDepth="3" BlurRadius="0" Opacity="1"/>
                                        </TextBlock.Effect>
                                        <Run Text="{Binding BmsVm.StatusMsg01.Ready, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </TextBlock>
                                </Label.Content>
                            </Label>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
            </Grid>
            <!-- Vegicle status -->

            <!-- PCS infomation-->
            <Border Grid.Column="0" Grid.Row="1" Margin="22,15,10,0" CornerRadius="12" Background="{DynamicResource Main.Panel.Background}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44*"/>
                        <ColumnDefinition Width="39*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="PCS INFORMATION" Style="{StaticResource HeadTextBlockStyle}"/>

                    <!--Run/Stop + Charge/Discharge-->
                    <Grid Grid.Column="0" Grid.Row="1" >
                        <Label Content="Operation Mode" Width="150" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <!-- INV 유효전력 -->
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                                    <Run Text="{Binding PcsVm.PanelData.Status, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>


                    <Grid Grid.Column="0" Grid.Row="2" >
                        <Label Content="Power" Width="150" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <!-- INV 유효전력 -->
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                                    <Run Text="{Binding PcsVm.InvData.Power, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Run Text="kW"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>
                    <Grid Grid.Column="0" Grid.Row="3" >
                        <Label Content="Voltage" Width="150" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <!-- 3상 선간전압 평균 -->
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding PcsVm.InvData.VoltAverage, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="V"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>
                    <Grid Grid.Column="0" Grid.Row="4" >
                        <Label Content="Error Code" Width="150" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <!-- PCS Error code -->
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding EMSStatusManager.PcsStatus.ErrorCode}"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>

                    <Grid Grid.Column="1" Grid.Row="1">
                        <Label Content="Set Power" Width="150" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <!-- battery max charge power -->
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding EMSStatusManager.PcsStatus.SetPower, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="kW"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>
                    <Grid Grid.Column="1" Grid.Row="2">
                        <Label Content="Current" Width="150" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <!-- 3상 전류 평균 -->
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding PcsVm.InvData.CurrAverage, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="A"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>
                    <Grid Grid.Column="1" Grid.Row="3">
                        <Label Content="Temperature" FontWeight="Light" Style="{StaticResource HeadLableStyle}"/>
                        <Label Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding PcsVm.InvItems[1].Value, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="℃"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>

                </Grid>
            </Border>

            <!-- System & Communication status-->
            <Border Grid.Column="0" Grid.Row="2" Margin="22,15,10,0" CornerRadius="12" Background="{DynamicResource Main.Panel.Background}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44*"/>
                        <ColumnDefinition Width="39*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height=".5*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="SYSTEM &amp; COMMUNICATION STATUS" Style="{StaticResource HeadTextBlockStyle}"/>
                    <TextBlock Grid.Column="1" Grid.Row="0" Text="BMS INFORMATION" Style="{StaticResource HeadTextBlockStyle}"/>

                    <Label Grid.Column="0" Grid.Row="1" Content="IPC State"
                           FontWeight="Light" HorizontalAlignment="Left" VerticalAlignment="Center"
                           Style="{StaticResource HeadLableStyle}" Height="30" Margin="15,13,0,14" Width="200"/>

                    <Label Grid.Column="0" Grid.Row="2" Content="Communication Status" 
                           FontWeight="Light" HorizontalAlignment="Left" VerticalAlignment="Center"
                           Style="{StaticResource HeadLableStyle}" Height="30" Margin="15,13,0,13" Width="200"/>

                    <Label Grid.Column="0" Grid.Row="3" Content="GPS Signal" 
                           FontWeight="Light" HorizontalAlignment="Left" VerticalAlignment="Center"
                           Style="{StaticResource HeadLableStyle}" Height="30" Margin="15,14,0,13" Width="200"/>

                    <Grid Grid.Column="1" Grid.Row="1">
                        <Label Content="State of Charge" Width="150" FontWeight="Light" 
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       Style="{StaticResource HeadLableStyle}"/>
                        <Label HorizontalAlignment="Right" Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                                <Run Text="{Binding EMSStatusManager.SystemComm.StateOfCharge, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                <Run Text="%"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>

                    <Grid Grid.Column="1" Grid.Row="2" >
                        <Label Content="State of Health" Width="150" FontWeight="Light" 
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,8"
                       Style="{StaticResource HeadLableStyle}"/>
                        <Label HorizontalAlignment="Right" Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                                <Run Text="{Binding EMSStatusManager.SystemComm.StateOfHealth, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                <Run Text="%"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </Grid>



                    <StackPanel Grid.Column="1" Grid.Row="3" Orientation="Horizontal">
                        <Label Content="Cell Voltage Range" FontWeight="Light" 
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,8"
                       Style="{StaticResource HeadLableStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.Row="4" Grid.RowSpan="2" Orientation="Vertical">
                        <Label Content="Cell Temperature Range" FontWeight="Light" 
                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,8,0,0"
                       Style="{StaticResource HeadLableStyle}"/>
                        <Label HorizontalAlignment="Right" Style="{StaticResource VariableLableStyle}">
                            <Label.Content>
                                <TextBlock>
                            <Run Text="{Binding EMSStatusManager.SystemComm.CellTemperatureRange, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                                </TextBlock>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Chart & Status -->
            <Grid Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" Margin="10,15,22,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2.6*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" VerticalAlignment="Stretch" CornerRadius="12" Background="{DynamicResource Main.Panel.Background}">
                    <!-- Chart -->
                    <Grid >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="ESS STATUS &amp; REAL-TIME CHART" Style="{StaticResource HeadTextBlockStyle}"/>

                        <s:SciChartSurface Grid.Row="1" Margin="15,0">
                            <!--  Declare RenderableSeries  -->
                            <s:SciChartSurface.RenderableSeries>
                                <s:FastMountainRenderableSeries x:Name="mountainRenderSeries" Fill="LightCyan" Stroke="Cyan" StrokeThickness="2">
                                    <s:FastMountainRenderableSeries.SeriesAnimation>
                                        <s:WaveAnimation AnimationDelay="0:0:0.2" Duration="0:0:2" PointDurationFraction="0.3"/>
                                    </s:FastMountainRenderableSeries.SeriesAnimation>
                                </s:FastMountainRenderableSeries>
                            </s:SciChartSurface.RenderableSeries>

                            <!--  Create an X Axis  -->
                            <s:SciChartSurface.XAxis>
                                <s:DateTimeAxis DrawMajorBands="False" DrawMajorTicks="False" DrawMajorGridLines="False"
                                        DrawMinorGridLines="False" DrawMinorTicks="False"/>
                            </s:SciChartSurface.XAxis>

                            <!--  Create a Y Axis. Optional bands give a cool look and feel for minimal performance impact  -->
                            <s:SciChartSurface.YAxis>
                                <s:NumericAxis DrawMajorBands="False" GrowBy="0.1, 0.1" VisibleRange="0,150" MaxAutoTicks="4"
                                       DrawMajorTicks="False" DrawMajorGridLines="True" 
                                       DrawMinorGridLines="False" DrawMinorTicks="False"/>
                            </s:SciChartSurface.YAxis>

                            <!--  Optional ChartModifier to add interactivity  -->
                            <s:SciChartSurface.ChartModifier>
                                <s:ModifierGroup>
                                    <s:RubberBandXyZoomModifier IsAnimated="False" IsXAxisOnly="True"
                                                        />
                                    <s:ZoomExtentsModifier/>
                                </s:ModifierGroup>
                            </s:SciChartSurface.ChartModifier>

                        </s:SciChartSurface>

                        <Grid Grid.Row="2">
                            <Label Content="Cumulative Charge Energy" FontWeight="Light" 
                           HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource HeadLableStyle}"/>
                            <Label Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                                <Label.Content>
                                    <TextBlock>
                            <Run Text="{Binding PcsVm.InvData.D_ImportEnergy, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="kWh"/>
                                    </TextBlock>
                                </Label.Content>
                            </Label>
                        </Grid>

                        <Grid Grid.Row="3">
                            <Label Content="Cumulative Discharge Energy" FontWeight="Light" 
                           HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource HeadLableStyle}"/>
                            <Label Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                                <Label.Content>
                                    <TextBlock>
                            <Run Text="{Binding PcsVm.InvData.D_ExportEnergy, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="kWh"/>
                                    </TextBlock>
                                </Label.Content>
                            </Label>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" VerticalAlignment="Stretch" Margin="0,15,0,0" CornerRadius="12" Background="{DynamicResource Main.Panel.Background}">
                    <!-- ESS Status -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="ESS STATUS" Style="{StaticResource HeadTextBlockStyle}"/>

                        <Grid Grid.Row="1">
                            <Label Content="Cumulative Charge Energy" FontWeight="Light" 
                           HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource HeadLableStyle}"/>
                            <Label Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                                <Label.Content>
                                    <TextBlock>
                            <Run Text="{Binding EMSStatusManager.EssStatus.CumulativeCharge, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="kWh"/>
                                    </TextBlock>
                                </Label.Content>
                            </Label>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Label Content="Cumulative Charge Energy" FontWeight="Light" 
                           HorizontalAlignment="Left" VerticalAlignment="Center" Style="{StaticResource HeadLableStyle}"/>
                            <Label Margin="0,0,15,0" Style="{StaticResource VariableLableStyle}">
                                <Label.Content>
                                    <TextBlock>
                            <Run Text="{Binding EMSStatusManager.EssStatus.CumulativeDischarge, Mode=TwoWay, Source={x:Static Application.Current}, UpdateSourceTrigger=PropertyChanged}"/>
                            <Run Text="kWh"/>
                                    </TextBlock>
                                </Label.Content>
                            </Label>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

    </Viewbox>
</UserControl>
