<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ViewModels="clr-namespace:EMS_PJT_Hamburger.ViewModels"
             xmlns:System="clr-namespace:System;assembly=mscorlib" 
             xmlns:local="clr-namespace:EMS_PJT_Hamburger.Views" xmlns:dxwui="http://schemas.devexpress.com/winfx/2008/xaml/windowsui"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors" xmlns:s="http://schemas.abtsoftware.co.uk/scichart" xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core" xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking" xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm" x:Class="EMS_PJT_Hamburger.Views.PCSView"
             mc:Ignorable="d" d:DesignHeight="860" d:DesignWidth="1200"  Background="Transparent" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR">
    <UserControl.Resources>
        <Style TargetType="{x:Type Label}" x:Key="HeadLableStyle">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type Border}" x:Key="MainBorderStyle">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource Main.Panel.Background}"/>
            <Setter Property="BorderBrush" Value="#FFF3F3F3"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="{x:Type TextBlock}" x:Key="HeadTextBlock">
            <Setter Property="FontFamily" Value="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/>
            <Setter Property="Foreground" Value="AliceBlue"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <Style TargetType="{x:Type Label}" x:Key="MonitorLabel">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="/EMS_PJT_Hamburger;component/Fonts/#Open 24 Display St"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="20,-3,5,0"/>
        </Style>

        <Style TargetType="{x:Type TextBlock}" x:Key="MonitorTextBlock">
            <Setter Property="FontFamily" Value="/EMS_PJT_Hamburger;component/Fonts/#Open 24 Display St"/>
            <Setter Property="Foreground" Value="AliceBlue"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        <!-- BorderBrush="#FFF3F3F3" BorderThickness="1"-->

        <Style TargetType="{x:Type Border}" x:Key="BorderCardStyle">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="{DynamicResource Main.Panel.Background}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderBrush" Value="#FFF3F3F3"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </UserControl.Resources>

    <!--<UserControl.DataContext>
        <ViewModels:PcsViewModel/>
    </UserControl.DataContext>-->

    <Viewbox>
        <dxdo:DockLayoutManager Height="860" Width="1200">
            <dxdo:DockLayoutManager.AutoHideGroups>
                <dxdo:AutoHideGroup DockType="Left" 
                                    HorizontalAlignment="Left">
                    <dxdo:LayoutPanel x:Name="CtrlSetPanel"
                                      Caption="Control" 
                                      AllowClose="False" 
                                      ShowCloseButton="False"
                                      MinWidth="250" MaxWidth="250"
                                      Foreground="Red" >
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="105"/>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="45"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>

                                <Label Content="기동모드" Grid.Row="0" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="0" Margin="2,4"
                                          SelectedValue="{Binding ControlOperationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="7: PMS 원격" Tag="7"/>
                                    <ComboBoxItem Content="1: 원격" Tag="1"/>
                                    <ComboBoxItem Content="0: 로컬" Tag="0"/>
                                </ComboBox>

                                <Label Content="충방전 모드" Grid.Row="1" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" Margin="2,4"
                                          SelectedValue="{Binding ControlChargeMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag">
                                    <ComboBoxItem Content="0: CC+CV" Tag="0"/>
                                    <ComboBoxItem Content="1: CP" Tag="1"/>
                                </ComboBox>

                                <Label Content="충전 전력(%)" Grid.Row="2" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="2" Margin="2,4" EditValue="{Binding ControlMaxChargePowerPercent, Mode=TwoWay, StringFormat=\{0:F2\}, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="%" Grid.Column="2" Grid.Row="2" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Label Content="방전 전력(%)" Grid.Row="3" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="3" Margin="2,4" EditValue="{Binding ControlMaxDischargePowerPercent, Mode=TwoWay, StringFormat=\{0:F2\}, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="%" Grid.Column="2" Grid.Row="3" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Label Content="최대 충전전력" Grid.Row="4" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="4" Margin="2,4" EditValue="{Binding ControlMaxChargePowerW, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="W" Grid.Column="2" Grid.Row="4" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Label Content="최대 방전전력" Grid.Row="5" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="5" Margin="2,4" EditValue="{Binding ControlMaxDischargePowerW, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="W" Grid.Column="2" Grid.Row="5" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Label Content="최대충전 SOC" Grid.Row="6" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="6" Margin="2,4" EditValue="{Binding ControlMaxChargeSoc, Mode=TwoWay, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="%" Grid.Column="2" Grid.Row="6" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Label Content="최소방전 SOC" Grid.Row="7" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="7" Margin="2,4" EditValue="{Binding ControlMinDischargeSoc, Mode=TwoWay, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="%" Grid.Column="2" Grid.Row="7" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Label Content="최대 충전전압" Grid.Row="8" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="8" Margin="2,4" EditValue="{Binding ControlMaxChargeVoltage, Mode=TwoWay, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="V" Grid.Column="2" Grid.Row="8" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Label Content="최대 방전전압" Grid.Row="9" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="9" Margin="2,4" EditValue="{Binding ControlMaxDischargeVoltage, Mode=TwoWay, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="V" Grid.Column="2" Grid.Row="9" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Label Content="최대 충전전류" Grid.Row="10" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="10" Margin="2,4" EditValue="{Binding ControlMaxChargeCurrent, Mode=TwoWay, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="A" Grid.Column="2" Grid.Row="10" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Label Content="최대 방전전류" Grid.Row="11" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="11" Margin="2,4" EditValue="{Binding ControlMaxDischargeCurrent, Mode=TwoWay, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="A" Grid.Column="2" Grid.Row="11" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Label Content="Grid 수전제한" Grid.Row="12" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="12" Margin="2,4" EditValue="{Binding ControlGridMaxImportPowerW, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="W" Grid.Column="2" Grid.Row="12" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <Label Content="Grid 송전제한" Grid.Row="13" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <dxe:TextEdit Grid.Column="1" Grid.Row="13" Margin="2,4" EditValue="{Binding ControlGridMaxExportPowerW, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                                <Label Content="W" Grid.Column="2" Grid.Row="13" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <dx:SimpleButton Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="3" Margin="2,4"
                                                 Content="충전 시작" Command="{Binding Cmd_StartCharge}"/>
                                <dx:SimpleButton Grid.Row="16" Grid.Column="0" Grid.ColumnSpan="3" Margin="2,4"
                                                 Content="방전 시작" Command="{Binding Cmd_StartDischarge}"/>
                                <StackPanel Grid.Row="17" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal">
                                    <dx:SimpleButton Width="115" Margin="2,4" Content="정지" Command="{Binding Cmd_StopPcs}"/>
                                    <dx:SimpleButton Width="115" Margin="2,4" Content="Reset" Command="{Binding Cmd_FaultReset}"/>
                                </StackPanel>
                                <dx:SimpleButton Grid.Row="18" Grid.Column="0" Grid.ColumnSpan="3" Margin="2,4" Content="Emergency Stop" Command="{Binding Cmd_EmergencyStop}">
                                    <dx:SimpleButton.Style>
                                        <Style TargetType="{x:Type dx:SimpleButton}">
                                            <Setter Property="Background" Value="#FFB94242"/>
                                            <Setter Property="BorderBrush" Value="#D94A4A"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#A83232"/>
                                                    <Setter Property="BorderBrush" Value="#FF7777"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#5F1515"/>
                                                    <Setter Property="BorderBrush" Value="#C93B3B"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </dx:SimpleButton.Style>
                                </dx:SimpleButton>
                                <dx:SimpleButton Grid.Row="19"
                                                 Grid.Column="0"
                                                 Grid.ColumnSpan="3"
                                                 Margin="2,4"
                                                 Content="Fault Message"
                                                 Command="{Binding Cmd_OpenFaultMessage}"
                                                 Glyph="{dx:DXImage 'SvgImages/Icon Builder/Security_Warning.svg'}"/>
                            </Grid>
                        </ScrollViewer>
                    </dxdo:LayoutPanel>
                </dxdo:AutoHideGroup>
            </dxdo:DockLayoutManager.AutoHideGroups>
            <dxdo:LayoutGroup Orientation="Vertical" >
                <dxdo:LayoutPanel Background="{DynamicResource Main.Background}" ShowCaption="False">
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="20"/>
                        </Grid.RowDefinitions>
                        <!-- System -->
                        <Grid Grid.Column="1" Grid.Row="1" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width=".8*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition Height="10"/>
                            </Grid.RowDefinitions>
                            <Border Grid.ColumnSpan="5" Grid.RowSpan="3" 
                                    Style="{StaticResource MainBorderStyle}"/>
                            <!-- system status -->
                            <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Orientation="Horizontal" Height="auto" HorizontalAlignment="Left" Margin="25,0,0,0">
                                <dx:DXImage Source="{dx:DXImage SvgImages/XAF/Action_Exit.svg}"
                                            Width="24" 
                                            Height="24" 
                                            Margin="0,2,0,0"/>

                                <TextBlock Text="시스템" FontSize="18" FontWeight="Bold"
                                           Style="{StaticResource HeadTextBlock}" Margin="5,0,0,1"/>
                                <TextBlock FontSize="14" Margin="15,0,0,0" Style="{StaticResource MonitorTextBlock}"><Run Text="Battery" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/></TextBlock>
                                <Ellipse Width="7" Height="7" Margin="5,1,0,0">
                                    <Ellipse.Style>
                                        <Style TargetType="{x:Type Ellipse}">
                                            <Setter Property="Fill" Value="Gray"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PanelData.BattReady}" Value="True">
                                                    <Setter Property="Fill" Value="Lime"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <TextBlock FontSize="14" Margin="15,0,0,0" Style="{StaticResource MonitorTextBlock}"><Run Text="Inverter" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/></TextBlock>
                                <Ellipse Width="7" Height="7" Margin="5,1,0,0">
                                    <Ellipse.Style>
                                        <Style TargetType="{x:Type Ellipse}">
                                            <Setter Property="Fill" Value="Gray"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PanelData.InvReady}" Value="True">
                                                    <Setter Property="Fill" Value="Lime"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <TextBlock FontSize="14" Margin="15,0,0,0" Style="{StaticResource MonitorTextBlock}"><Run Text="Grid" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/></TextBlock>
                                <Ellipse Width="7" Height="7" Margin="5,1,0,0">
                                    <Ellipse.Style>
                                        <Style TargetType="{x:Type Ellipse}">
                                            <Setter Property="Fill" Value="Gray"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PanelData.GridReady}" Value="True">
                                                    <Setter Property="Fill" Value="Lime"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <TextBlock FontSize="14" Margin="15,0,0,0" Style="{StaticResource MonitorTextBlock}"><Run Text="Comm" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/></TextBlock>
                                <Ellipse Width="7" Height="7" Margin="5,1,0,0">
                                    <Ellipse.Style>
                                        <Style TargetType="{x:Type Ellipse}">
                                            <Setter Property="Fill" Value="Gray"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PanelData.CommReady}" Value="True">
                                                    <Setter Property="Fill" Value="Lime"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>

                                <TextBlock FontSize="14" Margin="15,0,0,0" Style="{StaticResource MonitorTextBlock}"><Run Text="Bypass" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/></TextBlock>
                                <Ellipse Width="7" Height="7" Margin="5,1,0,0">
                                    <Ellipse.Style>
                                        <Style TargetType="{x:Type Ellipse}">
                                            <Setter Property="Fill" Value="Gray"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PanelData.BypassReady}" Value="True">
                                                    <Setter Property="Fill" Value="Lime"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </StackPanel>
                            <!-- system message -->
                            <StackPanel  Grid.Column="0" Grid.Row="1"  Orientation="Horizontal" Height="auto" HorizontalAlignment="Left" Margin="25,0,0,0">
                                <dx:DXImage Source="{dx:DXImage SvgImages/Icon Builder/Actions_Comment.svg}"
                                            Width="24" 
                                            Height="24" 
                                            Margin="0,0,0,0"/>
                                <TextBlock Style="{StaticResource MonitorTextBlock}" 
                                           FontSize="16"  
                                           FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR" 
                                           Foreground="White"
                                           Margin="5,0,0,5"
                                           Text="{Binding SystemMsg}"/>
                            </StackPanel>
                            <!-- alarm -->
                            <StackPanel Grid.Column="3" Grid.ColumnSpan="2" Grid.Row="1" Orientation="Horizontal" Height="auto" HorizontalAlignment="Left" Margin="25,0,0,0">
                                <dx:DXImage Source="{dx:DXImage SvgImages/XAF/Action_Bell.svg}"
                                            Width="24" 
                                            Height="24" 
                                            Margin="0,0,0,0"/>
                                <TextBlock FontSize="16" Margin="5,0,0,0" 
                                           Style="{StaticResource MonitorTextBlock}"><Run Text="알람" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/><Run Text=" "/><Run Text="{Binding PanelData.AlarmCnt}" Foreground="Lime" FontSize="20"/></TextBlock>
                            </StackPanel>
                            <!-- cumulative power-->
                            <Label Grid.Column="2" Grid.Row="0" 
                                   Width="200"
                                   Margin="0" 
                                   BorderBrush="White"
                                   BorderThickness="0,0,0,1"
                                   Style="{StaticResource HeadLableStyle}">
                                <StackPanel Margin="0" Orientation="Vertical">
                                    <TextBlock Text="수전 누적 전력(총합)"  
                                               Style="{StaticResource HeadTextBlock}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Label Content="{Binding PanelData.T_Import_Energy}" Foreground="Lime" Style="{StaticResource MonitorLabel}" Width="55"/>
                                        <TextBlock Text="MWh" Foreground="White" FontSize="14" Style="{StaticResource MonitorTextBlock}" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/>
                                    </StackPanel>
                                </StackPanel>
                            </Label>
                            <!-- system time -->
                            <StackPanel Grid.Column="3" Grid.Row="0" Orientation="Horizontal" Height="auto" HorizontalAlignment="Left" Margin="25,0,0,0">
                                <dx:DXImage Source="{dx:DXImage 'SvgImages/Spreadsheet/Time.svg'}"
                                            Width="24" 
                                            Height="24" 
                                            Margin="0,5,0,0"/>
                                <TextBlock Style="{StaticResource MonitorTextBlock}" 
                                           FontSize="16"  
                                           FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR" 
                                           Foreground="White"
                                           Margin="10,0,0,0"><Run Text="2026-03-11 00:00:00"/></TextBlock>
                            </StackPanel>
                            
                            

                            <Label Grid.Column="2" Grid.Row="1"            
                                   Margin="0"
                                   Style="{StaticResource HeadLableStyle}" Width="200">
                                <StackPanel Margin="0" Orientation="Vertical">
                                    <TextBlock Text="송전 누적 전력(총합)"
                                               Style="{StaticResource HeadTextBlock}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Label Content="{Binding PanelData.T_Export_Energy}" Foreground="Lime" Style="{StaticResource MonitorLabel}" Width="55"/>
                                        <TextBlock Text="MWh" Foreground="White" FontSize="14" Style="{StaticResource MonitorTextBlock}" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/>
                                    </StackPanel>
                                </StackPanel>
                            </Label>
                        </Grid>
                        <!-- Data View -->
                        <Grid Grid.Column="1" Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!-- Grid -->
                            <Border Grid.Column="0"
                                    Style="{StaticResource BorderCardStyle}">
                                <StackPanel>
                                    <Label Content="GRID"
                                           HorizontalAlignment="Left"
                                           FontWeight="Bold"
                                           FontSize="18"
                                           Style="{StaticResource HeadLableStyle}"/>
                                    <ItemsControl ItemsSource="{Binding GridItems}" Margin="0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0 2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="30"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Header}"
                                                               FontSize="14" 
                                                               Foreground="White" VerticalAlignment="Center" Grid.ColumnSpan="3"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14"
                                                               Foreground="#FFC3C3C3" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Value}"
                                                               Grid.Column="1"
                                                               Foreground="White"
                                                               VerticalAlignment="Center" 
                                                               HorizontalAlignment="Right" 
                                                               Margin="0,0,5,0"
                                                               FontSize="24"
                                                               FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Open 24 Display St"/>
                                                    <TextBlock Text="{Binding Factor}"
                                                               Grid.Column="2" 
                                                               FontSize="12"
                                                               Foreground="#FFC3C3C3" 
                                                               VerticalAlignment="Bottom"
                                                               HorizontalAlignment="Left"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Load -->
                            <Border Grid.Column="1"
                                    Style="{StaticResource BorderCardStyle}">
                                <StackPanel>
                                    <Label Content="LOAD"
                                           HorizontalAlignment="Left"
                                           FontWeight="Bold"
                                           FontSize="20"
                                           Style="{StaticResource HeadLableStyle}"/>
                                    <ItemsControl ItemsSource="{Binding LoadItems}" Margin="0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0 2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="30"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Header}"
                                                               FontSize="14" 
                                                               Foreground="White" VerticalAlignment="Center" Grid.ColumnSpan="3"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14"
                                                               Foreground="#FFC3C3C3" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Value}"
                                                               Grid.Column="1"
                                                               Foreground="White"
                                                               VerticalAlignment="Center" 
                                                               HorizontalAlignment="Right" 
                                                               Margin="0,0,5,0"
                                                               FontSize="24"
                                                               FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Open 24 Display St"/>
                                                    <TextBlock Text="{Binding Factor}"
                                                               Grid.Column="2" 
                                                               FontSize="12"
                                                               Foreground="#FFC3C3C3" 
                                                               VerticalAlignment="Bottom"
                                                               HorizontalAlignment="Left"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Inverter -->
                            <Border Grid.Column="2"
                                    Style="{StaticResource BorderCardStyle}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <Label Content="ETC"
                                               HorizontalAlignment="Left"
                                               FontWeight="Bold"
                                               FontSize="20"
                                               Style="{StaticResource HeadLableStyle}"/>

                                        <ItemsControl ItemsSource="{Binding EtcItems}" Margin="0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0 2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="30"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Header}"
                                                               FontSize="14" 
                                                               Foreground="White" VerticalAlignment="Center" Grid.ColumnSpan="3"/>
                                                        <TextBlock Text="{Binding Name}"
                                                               FontSize="14"
                                                               Foreground="#FFC3C3C3" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Value}"
                                                               Grid.Column="1"
                                                               Foreground="White"
                                                               VerticalAlignment="Center" 
                                                               HorizontalAlignment="Right" 
                                                               Margin="0,0,5,0"
                                                               FontSize="24"
                                                               FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Open 24 Display St"/>
                                                        <TextBlock Text="{Binding Factor}"
                                                               Grid.Column="2" 
                                                               FontSize="12"
                                                               Foreground="#FFC3C3C3" 
                                                               VerticalAlignment="Bottom"
                                                               HorizontalAlignment="Left"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- Chart -->
                            <Grid Grid.Column="3" Margin="10,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <s:SciChartSurface x:Name="D_ImportedEnergyChart" Grid.Row="0" Margin="0" Background="{x:Null}" BorderBrush="White" BorderThickness="0,0,1,1" Height="300">
                                    <!--  Declare RenderableSeries  -->
                                    <s:SciChartSurface.RenderableSeries>
                                        <s:FastMountainRenderableSeries Fill="LightCyan"
                                                                        Stroke="Lime"
                                                                        StrokeThickness="2"
                                                                        DataSeries="{Binding DailyImportedEnergySummarySeries}">
                                            <s:RolloverModifier.TooltipContainerStyle>
                                                <Style TargetType="s:TooltipControl">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                </Style>
                                            </s:RolloverModifier.TooltipContainerStyle>

                                            <s:RolloverModifier.TooltipTemplate>
                                                <DataTemplate>
                                                    <Border Background="#CC1E1E1E"
                                                            BorderBrush="Lime"
                                                            BorderThickness="1"
                                                            CornerRadius="3"
                                                            Padding="6,3">
                                                        <TextBlock Foreground="White"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold">
                                                            <Run Text="{Binding FormattedYValue, Mode=OneWay}" />
                                                            <Run Text=" kWh" />
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </s:RolloverModifier.TooltipTemplate>

                                            <s:FastMountainRenderableSeries.SeriesAnimation>
                                                <s:WaveAnimation AnimationDelay="0:0:0.2" Duration="0:0:2" PointDurationFraction="0.3"/>
                                            </s:FastMountainRenderableSeries.SeriesAnimation>
                                            <s:FastMountainRenderableSeries.PointMarker>
                                                <s:EllipsePointMarker Width="7"
                                                                      Height="7"
                                                                      Fill="White"
                                                                      Stroke="Lime"
                                                                      StrokeThickness="2"/>
                                            </s:FastMountainRenderableSeries.PointMarker>
                                            
                                        </s:FastMountainRenderableSeries>
                                    </s:SciChartSurface.RenderableSeries>

                                    <!--  Create an X Axis  -->
                                    <s:SciChartSurface.XAxis>
                                        <s:DateTimeAxis DrawMajorBands="False" 
                                                        DrawMajorTicks="False" 
                                                        DrawMajorGridLines="False"
                                                        DrawMinorGridLines="False" 
                                                        DrawMinorTicks="False"
                                                        TextFormatting="yyyy-MM-dd"
                                                        AxisTitle="수전 누적 전력 (MWh)" 
                                                        Foreground="LightGray">
                                        </s:DateTimeAxis>
                                    </s:SciChartSurface.XAxis>

                                    <!--  Create a Y Axis. Optional bands give a cool look and feel for minimal performance impact  -->
                                    <s:SciChartSurface.YAxis>
                                        <s:NumericAxis DrawMajorBands="False" 
                                                       GrowBy="0.1, 0.1" 
                                                       VisibleRange="0,500" 
                                                       MaxAutoTicks="4"
                                                       DrawMajorTicks="False" 
                                                       DrawMajorGridLines="True" 
                                                       DrawMinorGridLines="False" 
                                                       DrawMinorTicks="False"
                                                       AxisTitle="KWh"
                                                       Foreground="LightGray"/>
                                    </s:SciChartSurface.YAxis>

                                    <!--  Optional ChartModifier to add interactivity  -->
                                    <s:SciChartSurface.ChartModifier>
                                        <s:ModifierGroup>
                                            <s:MouseWheelZoomModifier/>
                                            <s:RubberBandXyZoomModifier IsAnimated="False" IsXAxisOnly="True"/>
                                            <s:ZoomExtentsModifier/>
                                            <s:RolloverModifier ReceiveHandledEvents="True"
                                                                DrawVerticalLine="True"
                                                                ShowTooltipOn="Always"
                                                                SourceMode="AllVisibleSeries"/>
                                        </s:ModifierGroup>
                                    </s:SciChartSurface.ChartModifier>
                                </s:SciChartSurface>

                                <s:SciChartSurface x:Name="D_ExportedEnergyChart" Grid.Row="1" Margin="0" Background="{x:Null}" BorderBrush="White" BorderThickness="0,0,1,1" Height="300">
                                    <!--  Declare RenderableSeries  -->
                                    <s:SciChartSurface.RenderableSeries>
                                        <s:FastMountainRenderableSeries x:Name="_dExportedEnergyRenderSeries"
                                                                        Fill="LightCyan"
                                                                        Stroke="Lime"
                                                                        StrokeThickness="2"
                                                                        DataSeries="{Binding DailyExportedEnergySummarySeries}">
                                            <s:RolloverModifier.TooltipContainerStyle>
                                                <Style TargetType="s:TooltipControl">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                </Style>
                                            </s:RolloverModifier.TooltipContainerStyle>

                                            <s:RolloverModifier.TooltipTemplate>
                                                <DataTemplate>
                                                    <Border Background="#CC1E1E1E"
                                                            BorderBrush="Lime"
                                                            BorderThickness="1"
                                                            CornerRadius="3"
                                                            Padding="6,3">
                                                        <TextBlock Foreground="White"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold">
                                                            <Run Text="{Binding FormattedYValue, Mode=OneWay}" />
                                                            <Run Text=" kWh" />
                                                        </TextBlock>
                                                    </Border>
                                                </DataTemplate>
                                            </s:RolloverModifier.TooltipTemplate>
                                            <s:FastMountainRenderableSeries.PointMarker>
                                                <s:EllipsePointMarker Width="7"
                                                                      Height="7"
                                                                      Fill="White"
                                                                      Stroke="Lime"
                                                                      StrokeThickness="2"/>
                                            </s:FastMountainRenderableSeries.PointMarker>
                                        </s:FastMountainRenderableSeries>
                                    </s:SciChartSurface.RenderableSeries>

                                    <!--  Create an X Axis  -->
                                    <s:SciChartSurface.XAxis>
                                        <s:DateTimeAxis DrawMajorBands="False" 
                                                        DrawMajorTicks="False" 
                                                        DrawMajorGridLines="False"
                                                        DrawMinorGridLines="False" 
                                                        DrawMinorTicks="False"
                                                        TextFormatting="yyyy-MM-dd"
                                                        AxisTitle="송전 누적 전력 (MWh)"
                                                        Foreground="LightGray"/>
                                    </s:SciChartSurface.XAxis>

                                    <!--  Create a Y Axis. Optional bands give a cool look and feel for minimal performance impact  -->
                                    <s:SciChartSurface.YAxis>
                                        <s:NumericAxis DrawMajorBands="False" 
                                                       GrowBy="0.1, 0.1" 
                                                       VisibleRange="0,500" 
                                                       MaxAutoTicks="4"
                                                       DrawMajorTicks="False" 
                                                       DrawMajorGridLines="True" 
                                                       DrawMinorGridLines="False" 
                                                       DrawMinorTicks="False"
                                                       AxisTitle="KWh"
                                                       Foreground="LightGray"/>
                                    </s:SciChartSurface.YAxis>

                                    <!--  Optional ChartModifier to add interactivity  -->
                                    <s:SciChartSurface.ChartModifier>
                                        <s:ModifierGroup>
                                            <s:MouseWheelZoomModifier/>
                                            <s:RubberBandXyZoomModifier IsAnimated="False" IsXAxisOnly="True"/>
                                            <s:ZoomExtentsModifier/>
                                            <s:RolloverModifier ReceiveHandledEvents="True"
                                                                DrawVerticalLine="True"
                                                                ShowTooltipOn="Always"
                                                                SourceMode="AllVisibleSeries"/>
                                        </s:ModifierGroup>
                                    </s:SciChartSurface.ChartModifier>
                                </s:SciChartSurface>
                            </Grid>

                        </Grid>

                        <Grid Grid.Column="1" Grid.Row="3">
                            <!--<Border Background="#FFF8F8F8" Margin="-5,0,0,0">
                                
                            </Border>-->
                        </Grid>
                    </Grid>
                </dxdo:LayoutPanel>
            </dxdo:LayoutGroup>

        </dxdo:DockLayoutManager>
    </Viewbox>
</UserControl>
