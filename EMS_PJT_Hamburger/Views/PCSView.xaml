<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ViewModels="clr-namespace:EMS_PJT_Hamburger.ViewModels"
             xmlns:System="clr-namespace:System;assembly=mscorlib" 
             xmlns:local="clr-namespace:EMS_PJT_Hamburger.Views" xmlns:dxwui="http://schemas.devexpress.com/winfx/2008/xaml/windowsui"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors" xmlns:s="http://schemas.abtsoftware.co.uk/scichart" xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core" xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking" x:Class="EMS_PJT_Hamburger.Views.PCSView"
             mc:Ignorable="d" d:DesignHeight="704" d:DesignWidth="964"  Background="Transparent" FontFamily="/EMS_PJT;component/Fonts/#Noto Sans KR">
    <UserControl.Resources>
        <Style TargetType="{x:Type Label}" x:Key="HeadLableStyle">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="{x:Type Border}" x:Key="MainBorderStyle">
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FFF3F3F3"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
        
        <Style TargetType="{x:Type TextBlock}" x:Key="HeadTextBlock">
            <Setter Property="FontFamily" Value="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/>
            <Setter Property="Foreground" Value="AliceBlue"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>

        <Style TargetType="{x:Type TextBlock}" x:Key="MonitorTextBlock">
            <Setter Property="FontFamily" Value="/EMS_PJT_Hamburger;component/Fonts/#Open 24 Display St"/>
            <Setter Property="Foreground" Value="AliceBlue"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        <!-- BorderBrush="#FFF3F3F3" BorderThickness="1"-->

        <Style TargetType="{x:Type Border}" x:Key="BorderCardStyle">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="#FFF3F3F3"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush>
                        <GradientStop Color="#0E1012" Offset="0"/>
                        <GradientStop Color="#FF2C3D4D" Offset="0.5"/>
                        <GradientStop Color="#0E1012" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="10"/>
        </Style>
    </UserControl.Resources>

    <UserControl.DataContext>
        <ViewModels:PcsViewModel/>
    </UserControl.DataContext>

    <Viewbox>
        <dxdo:DockLayoutManager Height="704" Width="964">
            <dxdo:LayoutGroup Orientation="Vertical" >
                <dxdo:LayoutPanel Background="{DynamicResource Main.Background}" ShowCaption="False">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="120"/>
                        </Grid.RowDefinitions>
                        <!-- System -->
                        <Grid Grid.Column="1" Grid.Row="1" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition Height="10"/>
                            </Grid.RowDefinitions>
                            <Border Grid.ColumnSpan="5" Grid.RowSpan="3" 
                                    Style="{StaticResource MainBorderStyle}">
                            </Border>

                            <Label Grid.Column="0" Grid.Row="0"
                                   Width="200"
                                   Margin="0" 
                                   BorderBrush="White" 
                                   BorderThickness="0,0,0,1"
                                   Style="{StaticResource HeadLableStyle}">
                                <TextBlock FontSize="16" Margin="0,0,0,0" 
                                           Style="{StaticResource MonitorTextBlock}">
                                        <Run Text="시스템" FontSize="14"/>
                                        <Run Text="정상" Foreground="Lime"/>
                                </TextBlock>
                            </Label>

                            <Label Grid.Column="1" Grid.Row="0"
                                   Width="200"
                                   Margin="0" 
                                   BorderBrush="White" 
                                   BorderThickness="0,0,0,1"
                                   Style="{StaticResource HeadLableStyle}" >
                                <TextBlock Margin="0,0,0,0"
                                           Style="{StaticResource MonitorTextBlock}">
                                        <Run Text="알람" FontSize="14"/>
                                        <Run Text="0" Foreground="Lime" FontSize="20"/>
                                </TextBlock>
                            </Label>

                            <Label Grid.Column="2" Grid.Row="0" 
                                   Width="200"
                                   Margin="0" 
                                   BorderBrush="White"
                                   BorderThickness="0,0,0,1"
                                   Style="{StaticResource HeadLableStyle}">
                                <StackPanel Margin="0" Orientation="Vertical">
                                    <TextBlock Text="수전 누적 전력(총합)"  
                                               Style="{StaticResource HeadTextBlock}"/>
                                    <TextBlock Style="{StaticResource MonitorTextBlock}">
                                            <Run Text="12.45" Foreground="Lime"/>
                                            <Run Text="MWh" Foreground="White" FontSize="14" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/>
                                    </TextBlock>
                                </StackPanel>
                            </Label>

                            <Label Grid.Column="3" Grid.Row="0"
                                   Width="200"
                                   Margin="0" 
                                   BorderBrush="White" 
                                   BorderThickness="0,0,0,1"
                                   Style="{StaticResource HeadLableStyle}">
                                <StackPanel Margin="0" Orientation="Vertical">
                                    <TextBlock Text="수전 누적 전력(일간)"
                                               Style="{StaticResource HeadTextBlock}"/>
                                    <TextBlock Style="{StaticResource MonitorTextBlock}">
                                            <Run Text="124.40" Foreground="Lime"/>
                                            <Run Text="kWh" Foreground="White" FontSize="14" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR" />
                                    </TextBlock>
                                </StackPanel>
                            </Label>

                            <Label Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"            
                                   Margin="0"
                                   Style="{StaticResource HeadLableStyle}" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" Margin="50,0,0,0">
                                    <Image Source="pack://application:,,,/DevExpress.Images.v23.1;component/SvgImages/XAF/State_Task_InProgress.svg"
                                           Width="20" 
                                           Height="20" 
                                           Margin="0"/>
                                    <TextBlock Style="{StaticResource MonitorTextBlock}" 
                                               FontSize="16"  
                                               FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR" 
                                               Margin="10,0,0,0">
                                            <Run Text="2026-02-27"/>
                                    </TextBlock>
                                </StackPanel>
                            </Label>

                            <Label Grid.Column="2" Grid.Row="1"            
                                   Margin="0"
                                   Style="{StaticResource HeadLableStyle}" Width="200">
                                <StackPanel Margin="0" Orientation="Vertical">
                                    <TextBlock Text="송전 누적 전력(총합)"
                                               Style="{StaticResource HeadTextBlock}"/>
                                    <TextBlock Style="{StaticResource MonitorTextBlock}">
                                            <Run Text="8.96" Foreground="Lime"/>
                                            <Run Text="MWh" Foreground="White" FontSize="14" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/>
                                    </TextBlock>
                                </StackPanel>
                            </Label>

                            <Label Grid.Column="3" Grid.Row="1"            
                                   Margin="0"
                                   Style="{StaticResource HeadLableStyle}" Width="200">
                                <StackPanel Margin="0" Orientation="Vertical">
                                    <TextBlock Text="송전 누적 전력(일간)"
                                                Style="{StaticResource HeadTextBlock}"/>
                                    <TextBlock Style="{StaticResource MonitorTextBlock}">
                                            <Run Text="5.4" Foreground="Lime"/>
                                            <Run Text="kWh" Foreground="White" FontSize="14" FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR"/>
                                    </TextBlock>
                                </StackPanel>
                            </Label>
                        </Grid>
                        <!-- Data View -->
                        <Grid Grid.Column="1" Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!-- Grid -->
                            <Border Grid.Column="0"
                                    Style="{StaticResource BorderCardStyle}">
                                <StackPanel>
                                    <Label Content="GRID"
                                           HorizontalAlignment="Left"
                                           FontWeight="Bold"
                                           FontSize="20"
                                           Style="{StaticResource HeadLableStyle}"/>
                                    <ItemsControl ItemsSource="{Binding GridItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0 2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="30"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Header}"
                                                               FontSize="14" 
                                                               Foreground="White" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="11"
                                                               Foreground="LightGray" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Value}"
                                                               Grid.Column="1"
                                                               Foreground="White"
                                                               VerticalAlignment="Center" 
                                                               HorizontalAlignment="Right" 
                                                               Margin="0,0,5,0"
                                                               FontSize="18" 
                                                               FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Open 24 Display St">
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Factor}"
                                                               Grid.Column="2" 
                                                               FontSize="11"
                                                               Foreground="LightGray" 
                                                               VerticalAlignment="Bottom"
                                                               HorizontalAlignment="Left"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Load -->
                            <Border Grid.Column="1"
                                    Style="{StaticResource BorderCardStyle}">
                                <StackPanel>
                                    <Label Content="LOAD"
                                           HorizontalAlignment="Left"
                                           FontWeight="Bold"
                                           FontSize="20"
                                           Style="{StaticResource HeadLableStyle}"/>
                                    <ItemsControl ItemsSource="{Binding LoadItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0 2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="30"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Header}"
                                                               FontSize="14" 
                                                               Foreground="White" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="11"
                                                               Foreground="LightGray" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Value}"
                                                               Grid.Column="1"
                                                               Foreground="White"
                                                               VerticalAlignment="Center" 
                                                               HorizontalAlignment="Right" 
                                                               Margin="0,0,5,0"
                                                               FontSize="18" 
                                                               FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Open 24 Display St">
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Factor}"
                                                               Grid.Column="2" 
                                                               FontSize="11"
                                                               Foreground="LightGray" 
                                                               VerticalAlignment="Bottom"
                                                               HorizontalAlignment="Left"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Inverter -->
                            <Border Grid.Column="2"
                                    Style="{StaticResource BorderCardStyle}">
                                <StackPanel>
                                    <Label Content="INVERTER"
                                           HorizontalAlignment="Left"
                                           FontWeight="Bold"
                                           FontSize="20"
                                           Style="{StaticResource HeadLableStyle}"/>
                                    <ItemsControl ItemsSource="{Binding InvItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0 2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="30"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Header}"
                                                               FontSize="14" 
                                                               Foreground="White" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="11"
                                                               Foreground="LightGray" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Value}"
                                                               Grid.Column="1"
                                                               Foreground="White"
                                                               VerticalAlignment="Center" 
                                                               HorizontalAlignment="Right" 
                                                               Margin="0,0,5,0"
                                                               FontSize="18" 
                                                               FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Open 24 Display St">
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Factor}"
                                                               Grid.Column="2" 
                                                               FontSize="11"
                                                               Foreground="LightGray" 
                                                               VerticalAlignment="Bottom"
                                                               HorizontalAlignment="Left"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Chart -->
                            <Grid Grid.Column="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <s:SciChartSurface Grid.Row="0" Margin="5,5,7,5" Background="{x:Null}" BorderBrush="White" BorderThickness="0,0,1,1">
                                    <!--  Declare RenderableSeries  -->
                                    <s:SciChartSurface.RenderableSeries>
                                        <s:FastMountainRenderableSeries x:Name="mountainRenderSeries" Fill="LightCyan" Stroke="Lime" StrokeThickness="2">
                                            <s:FastMountainRenderableSeries.SeriesAnimation>
                                                <s:WaveAnimation AnimationDelay="0:0:0.2" Duration="0:0:2" PointDurationFraction="0.3"/>
                                            </s:FastMountainRenderableSeries.SeriesAnimation>
                                        </s:FastMountainRenderableSeries>
                                    </s:SciChartSurface.RenderableSeries>

                                    <!--  Create an X Axis  -->
                                    <s:SciChartSurface.XAxis>
                                        <s:DateTimeAxis DrawMajorBands="False" 
                                                        DrawMajorTicks="False" 
                                                        DrawMajorGridLines="False"
                                                        DrawMinorGridLines="False" 
                                                        DrawMinorTicks="False"
                                                        AxisTitle="수전 누적량 (일간)" 
                                                        Foreground="LightGray"/>
                                    </s:SciChartSurface.XAxis>

                                    <!--  Create a Y Axis. Optional bands give a cool look and feel for minimal performance impact  -->
                                    <s:SciChartSurface.YAxis>
                                        <s:NumericAxis DrawMajorBands="False" 
                                                       GrowBy="0.1, 0.1" 
                                                       VisibleRange="0,150" 
                                                       MaxAutoTicks="4"
                                                       DrawMajorTicks="False" 
                                                       DrawMajorGridLines="True" 
                                                       DrawMinorGridLines="False" 
                                                       DrawMinorTicks="False"
                                                       Foreground="LightGray"/>
                                    </s:SciChartSurface.YAxis>

                                    <!--  Optional ChartModifier to add interactivity  -->
                                    <s:SciChartSurface.ChartModifier>
                                        <s:ModifierGroup>
                                            <s:RubberBandXyZoomModifier IsAnimated="False" IsXAxisOnly="True"/>
                                            <s:ZoomExtentsModifier/>
                                        </s:ModifierGroup>
                                    </s:SciChartSurface.ChartModifier>
                                </s:SciChartSurface>

                                <s:SciChartSurface Grid.Row="1" Margin="5,5,7,5" Background="{x:Null}" BorderBrush="White" BorderThickness="0,0,1,1">
                                    <!--  Declare RenderableSeries  -->
                                    <s:SciChartSurface.RenderableSeries>
                                        <s:FastMountainRenderableSeries x:Name="mountainRenderSeries1" Fill="LightCyan" Stroke="Lime" StrokeThickness="2">
                                            <s:FastMountainRenderableSeries.SeriesAnimation>
                                                <s:WaveAnimation AnimationDelay="0:0:0.2" Duration="0:0:2" PointDurationFraction="0.3"/>
                                            </s:FastMountainRenderableSeries.SeriesAnimation>
                                        </s:FastMountainRenderableSeries>
                                    </s:SciChartSurface.RenderableSeries>

                                    <!--  Create an X Axis  -->
                                    <s:SciChartSurface.XAxis>
                                        <s:DateTimeAxis DrawMajorBands="False" 
                                                        DrawMajorTicks="False" 
                                                        DrawMajorGridLines="False"
                                                        DrawMinorGridLines="False" 
                                                        DrawMinorTicks="False"
                                                        AxisTitle="송전 누적량 (일간)"
                                                        Foreground="LightGray"/>
                                    </s:SciChartSurface.XAxis>

                                    <!--  Create a Y Axis. Optional bands give a cool look and feel for minimal performance impact  -->
                                    <s:SciChartSurface.YAxis>
                                        <s:NumericAxis DrawMajorBands="False" 
                                                       GrowBy="0.1, 0.1" 
                                                       VisibleRange="0,150" 
                                                       MaxAutoTicks="4"
                                                       DrawMajorTicks="False" 
                                                       DrawMajorGridLines="True" 
                                                       DrawMinorGridLines="False" 
                                                       DrawMinorTicks="False"
                                                       Foreground="LightGray"/>
                                    </s:SciChartSurface.YAxis>

                                    <!--  Optional ChartModifier to add interactivity  -->
                                    <s:SciChartSurface.ChartModifier>
                                        <s:ModifierGroup>
                                            <s:RubberBandXyZoomModifier IsAnimated="False" IsXAxisOnly="True"/>
                                            <s:ZoomExtentsModifier/>
                                        </s:ModifierGroup>
                                    </s:SciChartSurface.ChartModifier>

                                </s:SciChartSurface>
                            </Grid>

                        </Grid>
                    </Grid>
                </dxdo:LayoutPanel>
            </dxdo:LayoutGroup>

            <dxdo:DockLayoutManager.AutoHideGroups>
                <dxdo:AutoHideGroup DockType="Left" 
                                    HorizontalAlignment="Left">
                    <dxdo:LayoutPanel x:Name="CtrlSetPanel"
                                      Caption="Control" 
                                      AllowClose="False" 
                                      ShowCloseButton="False"
                                      MinWidth="250" MaxWidth="250"
                                      Foreground="Red" >
                    </dxdo:LayoutPanel>
                </dxdo:AutoHideGroup>
            </dxdo:DockLayoutManager.AutoHideGroups>
        </dxdo:DockLayoutManager>
    </Viewbox>
</UserControl>
