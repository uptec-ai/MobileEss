                            </Grid>
                        </Grid>-->

                                </Grid>
                            </ScrollViewer>
                            <TextBlock Grid.ColumnSpan="8" 
                                       Grid.Row="0"
                                       Margin="20,5,0,0" 
                                       Text="Xpack monitoring"
                                       Style="{StaticResource HeadTextBlockStyle}"/>
                        </Grid>
                    </Grid>
                </dxdo:LayoutPanel>
            </dxdo:LayoutGroup>

            <dxdo:DockLayoutManager.AutoHideGroups>
                <dxdo:AutoHideGroup DockType="Left">
                    <dxdo:LayoutPanel x:Name="CtrlSetPanel"
                                      Caption="Control" 
                                      AllowClose="False" 
                                      ShowCloseButton="False"
                                      MinWidth="250" MaxWidth="250"
                                      Foreground="Red">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Label Content="Relay 제어" Grid.Column="0" Grid.Row="1"
                                   Foreground="Black"
                                   Style="{StaticResource HeadLableStyle}"/>
                            <dx:SimpleButton Grid.Column="1" Grid.Row="1"
                                             Padding="0"
                                             Margin="5,5,10,5"
                                             ButtonKind="Toggle"
                                             Content="{Binding RelayStatus, Converter={StaticResource RelayConverter}}" 
                                             IsChecked="{Binding RelayStatus}"
                                             Command="{Binding Cmd_RelayBtn}"/>
                            <Label Content="Alarm"
                                   Grid.Column="0"
                                   Grid.Row="2"
                                   Foreground="Black"
                                   Style="{StaticResource HeadLableStyle}"/>
                            <Label Content="{Binding Alarms}"
                                   Grid.Column="1"
                                   Grid.Row="2"
                                   Foreground="Black"
                                   Style="{StaticResource HeadLableStyle}"/>
                            <dx:SimpleButton Grid.Column="0" Grid.ColumnSpan="2"
                                             Grid.Row="3"
                                             Padding="0"
                                             Margin="10,5"
                                             Content="BMS Fault Message"
                                             IsEnabled="{Binding AlarmWindowOpen}"
                                             Command="{Binding Cmd_AlarmsPopupBtn}"
                                             Glyph="{dx:DXImage 'SvgImages/Icon Builder/Security_Warning.svg'}"/>
                        </Grid>
                    </dxdo:LayoutPanel>
                </dxdo:AutoHideGroup>
            </dxdo:DockLayoutManager.AutoHideGroups>
        </dxdo:DockLayoutManager>
    </Viewbox>
</UserControl>
