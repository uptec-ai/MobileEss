<Window x:Class="EMS_PJT_Hamburger.Views.AlarmDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ViewModels="clr-namespace:EMS_PJT_Hamburger.ViewModels"
        xmlns:Managers="clr-namespace:EMS_PJT_Hamburger.Models.Managers" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid" 
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EMS_PJT_Hamburger.Views" 
        mc:Ignorable="d"
        Title="{Binding SourceName, StringFormat={}{0} ALARM}"
        Icon="{dx:DXImage 'SvgImages/Icon Builder/Security_Warning.svg'}"
        d:DataContext="{d:DesignInstance Type=ViewModels:AlarmDetailWindowViewModel}"
        Height="420" Width="860">
    <Window.Resources>
        <!--SimpleButton Style-->
        <Style x:Key="SimpleButtonStyle" TargetType="dx:SimpleButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFABABAB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <!--Font-->
            <Setter Property="Foreground" Value="#FF646464"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontFamily" Value="/EMS_PJT_Hamburger;component/Fonts/#NanumSquareRound Bold"/>
            <!--Figure-->
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="GlyphWidth" Value="20"/>
            <Setter Property="GlyphHeight" Value="20"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="dx:ThemeManager.ThemeName" Value="Office2019Colorful"/>
        </Style>


    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0">
            <CheckBox Content="All" FontSize="10" Margin="5,0,0,0" Foreground="Black"
                      IsChecked="{Binding SelectAll, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderBrush="#FFABABAB" Height="30" VerticalAlignment="Top"/>

            <CheckBox Content="Top 100" FontSize="10" Margin="20,0,0,0" Foreground="Black"
                      IsChecked="{Binding SelectTop100, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderBrush="#FFABABAB"/>

            <CheckBox Content="Occurred Alarm" FontSize="10" Margin="20,0,0,0" Foreground="Black"
                      IsChecked="{Binding SelectCurrent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" BorderBrush="#FFABABAB"/>
        </StackPanel>

        <dxg:GridControl Name="grid" SelectionMode="Row" Grid.Row="1"
                         ShowBorder="True"
                         ItemsSource="{Binding Alarms}">
            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="OccurredAt"
                                Header="Time"
                                Width="145"
                                AllowEditing="False">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings DisplayFormat="yyyy-MM-dd HH:mm:ss"/>
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="Source"
                                Header="Source"
                                Width="65"
                                AllowEditing="False"/>
                <dxg:GridColumn FieldName="Category"
                                Header="Category"
                                Width="100"
                                AllowEditing="False"/>
                <dxg:GridColumn FieldName="Bit"
                                Header="Bit"
                                Width="45"
                                AllowEditing="False"/>
                <dxg:GridColumn FieldName="Code"
                                Header="Code"
                                Width="55"
                                AllowEditing="False"/>
                <dxg:GridColumn FieldName="FaultMessage"
                                Header="Fault Message"
                                Width="*"
                                AllowEditing="False"/>
                <dxg:GridColumn FieldName="RawValue"
                                Header="Raw"
                                Width="70"
                                AllowEditing="False"/>
                <dxg:GridColumn FieldName="Hour"
                                Header="Hour"
                                AllowEditing="False"
                                Width="70"/>
            </dxg:GridControl.Columns>

            <dxg:GridControl.View>
                <dxg:TableView ShowGroupPanel="False"
                               AllowGrouping="False"
                               AllowSorting="False"
                               NavigationStyle="Row"
                               ShowIndicator="False"
                               IsColumnMenuEnabled="False"
                               AllowDragDrop="True"
                               ShowDragDropHint="False"
                               AllowPrintColumnHeaderImage="True">
                </dxg:TableView>
            </dxg:GridControl.View>
        </dxg:GridControl>

        <StackPanel Orientation="Horizontal" Grid.Row="2">
            <!-- Load Data -->
            <dx:SimpleButton x:Name="btn_loadData" Grid.Row="1" Grid.Column="1" 
                             Content="Load Data" ToolTip="알람 불러오기" 
                             Style="{StaticResource SimpleButtonStyle}"
                             Glyph="{dx:DXImage 'SvgImages/Spreadsheet/ManageQueries.svg'}" 
                             Command="{Binding Cmd_LoadAlarm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Insert Data -->
            <dx:SimpleButton x:Name="btn_selectData" Grid.Row="1" Grid.Column="1" 
                             Content="Export TXT" ToolTip="알람 내보내기" 
                             Style="{StaticResource SimpleButtonStyle}"
                             Glyph="{dx:DXImage 'SvgImages/Export/ExportToTXT.svg'}" 
                             Command="{Binding Cmd_ExportAlarm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
    </Grid>
</Window>
