<UserControl x:Class="EMS_PJT_Hamburger.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1200"
             Background="Transparent"
             FontFamily="/EMS_PJT_Hamburger;component/Fonts/#Noto Sans KR">
    <UserControl.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Main.Panel.Background}"/>
            <Setter Property="BorderBrush" Value="#334F5E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFB0FCFC"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFA6A6A6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="{x:Type dx:SimpleButton}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#244656"/>
            <Setter Property="BorderBrush" Value="#87FFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="HistoryDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#263642"/>
            <Setter Property="RowBackground" Value="#10161D"/>
            <Setter Property="AlternatingRowBackground" Value="#151E27"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#22313E"/>
            <Setter Property="Foreground" Value="#FFB0FCFC"/>
            <Setter Property="BorderBrush" Value="#334F5E"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Viewbox>
        <Grid Width="1200" Height="860" Background="{DynamicResource Main.Background}" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="74"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="260"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Margin="12,8">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Text="HISTORY" Foreground="White" FontSize="26" FontWeight="Bold"/>
                        <TextBlock Text="PCS / BMS data, alarm and trend" Style="{StaticResource MutedTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="Start" Style="{StaticResource MutedTextStyle}" Margin="0,0,6,0"/>
                        <DatePicker SelectedDate="{Binding StartDate, Mode=TwoWay}" Width="125" Height="28"/>
                        <TextBlock Text="End" Style="{StaticResource MutedTextStyle}" Margin="16,0,6,0"/>
                        <DatePicker SelectedDate="{Binding EndDate, Mode=TwoWay}" Width="125" Height="28"/>
                        <dx:SimpleButton Content="Today" Style="{StaticResource ActionButtonStyle}" Command="{Binding Cmd_Today}"/>
                        <dx:SimpleButton Content="Week" Style="{StaticResource ActionButtonStyle}" Command="{Binding Cmd_Week}"/>
                        <dx:SimpleButton Content="Refresh" Style="{StaticResource ActionButtonStyle}" Command="{Binding Cmd_Refresh}"
                                         Glyph="{dx:DXImage 'SvgImages/Actions/Refresh.svg'}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="{Binding StatusMessage}"
                               Foreground="#FFC3C3C3"
                               FontSize="12"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Border>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding MetricCards}" Margin="12,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,10,8" BorderBrush="{Binding Accent}">
                            <Grid Margin="14,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource MutedTextStyle}"/>
                                    <TextBlock Text="{Binding Value}" Foreground="White" FontSize="27" FontWeight="Bold" Margin="0,6,0,0"/>
                                </StackPanel>
                                <Ellipse Grid.Column="1" Width="12" Height="12" Fill="{Binding Accent}" VerticalAlignment="Top"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="2" Margin="12,0,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,6,0">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PCS Trend" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Grid imported/exported energy" Style="{StaticResource MutedTextStyle}" Margin="12,0,0,0"/>
                        </StackPanel>
                        <Border Grid.Row="1" Background="#0D1218" BorderBrush="#263642" BorderThickness="1">
                            <Canvas Width="720" Height="190" Margin="10">
                                <Line X1="0" Y1="190" X2="720" Y2="190" Stroke="#263642" StrokeThickness="1"/>
                                <Line X1="0" Y1="95" X2="720" Y2="95" Stroke="#1E2B35" StrokeThickness="1"/>
                                <Polyline Points="{Binding PcsChartPoints}" Stroke="#76F7A8" StrokeThickness="3"/>
                            </Canvas>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="6,0,0,0">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="BMS Trend" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="SOC based visualization" Style="{StaticResource MutedTextStyle}" Margin="12,0,0,0"/>
                        </StackPanel>
                        <Border Grid.Row="1" Background="#0D1218" BorderBrush="#263642" BorderThickness="1">
                            <Canvas Width="720" Height="190" Margin="10">
                                <Line X1="0" Y1="190" X2="720" Y2="190" Stroke="#263642" StrokeThickness="1"/>
                                <Line X1="0" Y1="95" X2="720" Y2="95" Stroke="#1E2B35" StrokeThickness="1"/>
                                <Polyline Points="{Binding BmsChartPoints}" Stroke="#87FFFF" StrokeThickness="3"/>
                            </Canvas>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="3" Margin="12,0,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Margin="0,0,6,0">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="PCS Data" Style="{StaticResource SectionTitleStyle}"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding PcsRows}" Style="{StaticResource HistoryDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="140"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="95"/>
                                <DataGridTextColumn Header="Value 1" Binding="{Binding Value1}" Width="70"/>
                                <DataGridTextColumn Header="Value 2" Binding="{Binding Value2}" Width="70"/>
                                <DataGridTextColumn Header="Unit" Binding="{Binding Value3}" Width="55"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Margin="6,0">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="BMS Data" Style="{StaticResource SectionTitleStyle}"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding BmsRows}" Style="{StaticResource HistoryDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="140"/>
                                <DataGridTextColumn Header="SOC" Binding="{Binding Value1}" Width="60"/>
                                <DataGridTextColumn Header="Volt" Binding="{Binding Value2}" Width="70"/>
                                <DataGridTextColumn Header="Curr" Binding="{Binding Value3}" Width="70"/>
                                <DataGridTextColumn Header="State" Binding="{Binding Name}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Margin="6,0,0,0">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Alarm History" Style="{StaticResource SectionTitleStyle}"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding AlarmRows}" Style="{StaticResource HistoryDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="140"/>
                                <DataGridTextColumn Header="Src" Binding="{Binding Source}" Width="45"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="75"/>
                                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="45"/>
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Viewbox>
</UserControl>
